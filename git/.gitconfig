# ╔══════════════════════════════════════════════════════════════════╗
# ║  .gitconfig  ·  Managed by dotfiles                            ║
# ║                                                                 ║
# ║  Set your name/email in ~/.gitconfig.local:                     ║
# ║    [user]                                                       ║
# ║        name = Your Name                                         ║
# ║        email = your@email.com                                   ║
# ╚══════════════════════════════════════════════════════════════════╝

[include]
    path = ~/.gitconfig.local

[init]
    defaultBranch = main

[core]
    editor = nano
    autocrlf = input
    excludesFile = ~/.gitignore_global
    # Use delta for syntax-highlighted diffs (falls back to less if not installed)
    pager = delta --dark 2>/dev/null || less -FRX

[color]
    ui = auto

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    # Catppuccin Mocha theme
    minus-style = "syntax #53394c"
    minus-emph-style = "syntax #6b3a50"
    plus-style = "syntax #394634"
    plus-emph-style = "syntax #4a6b3a"
    line-numbers-minus-style = "#f38ba8"
    line-numbers-plus-style = "#a6e3a1"
    line-numbers-zero-style = "#6c7086"
    hunk-header-style = "syntax bold"
    hunk-header-decoration-style = "#89b4fa ul"

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[merge]
    conflictStyle = diff3

[interactive]
    diffFilter = delta --color-only 2>/dev/null || cat

[diff]
    colorMoved = default

[alias]
    s  = status -sb
    l  = log --oneline --graph --decorate -20
    la = log --oneline --graph --decorate --all -30
    d  = diff
    ds = diff --staged
    co = checkout
    cb = checkout -b
    cm = commit -m
    ca = commit -am
    p  = pull
    pu = push
    pf = push --force-with-lease
    br = branch
    st = stash
    sp = stash pop
    undo = reset --soft HEAD~1
    amend = commit --amend --no-edit
    wip = !git add -A && git commit -m 'WIP'
    # Show last commit
    last = log -1 HEAD --stat
    # Pretty log with dates
    history = log --pretty=format:'%C(yellow)%h%Creset %C(green)%ad%Creset | %s%C(red)%d%Creset %C(blue)[%an]%Creset' --date=short

[url "git@github.com:"]
    insteadOf = https://github.com/
